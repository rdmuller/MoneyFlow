{
  "ConnectionStrings": {
    //"DefaultConnection": "Data Source=prog032;Initial Catalog=MoneyFlow;Integrated Security=True;Connect Timeout=30;Encrypt=True;Trust Server Certificate=True;Application Intent=ReadWrite;Multi Subnet Failover=False;Command Timeout=30"
    //"DefaultConnection": "Host=localhost;Port=5432;Database=moneyflow;Username=postgres;Password=postgres;"
    "DefaultConnection": "Host=moneyflow-db;Port=5432;Database=moneyflow;Username=postgres;Password=postgres;"
  },
  "Settings": {
    "jwt": {
      "ExpiresMinutes": 9999,
      "SigningKey": "wwwwwwwwwwwwwwww"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Evently.Modules.Attendance.Infrastructure.Outbox": "Warning",
        "Evently.Modules.Attendance.Infrastructure.Inbox": "Warning",
        "Evently.Modules.Events.Infrastructure.Outbox": "Warning",
        "Evently.Modules.Events.Infrastructure.Inbox": "Warning",
        "Evently.Modules.Ticketing.Infrastructure.Outbox": "Warning",
        "Evently.Modules.Ticketing.Infrastructure.Inbox": "Warning",
        "Evently.Modules.Users.Infrastructure.Outbox": "Warning",
        "Evently.Modules.Users.Infrastructure.Inbox": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://moneyflow.seq:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "MoneyFlow.Api"
    }
  },
  "xSerilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "MoneyFlow.Api"
    }
  }
}