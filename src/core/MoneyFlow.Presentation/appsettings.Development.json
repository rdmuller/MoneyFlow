        "Args": { "serverUrl": "http://moneyflow.seq:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "MoneyFlow.Api"
    }
